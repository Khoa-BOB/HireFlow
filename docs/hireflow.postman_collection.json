{
  "info": {
    "name": "HireFlow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "company_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/registry",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"full_name\": \"New User\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "    pm.collectionVariables.set('access_token', res.access_token);",
                  "}",
                  "if (res.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', res.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hireflow.dev\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login (Candidate)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "    pm.collectionVariables.set('access_token', res.access_token);",
                  "}",
                  "if (res.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', res.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"candidate@hireflow.dev\",\n  \"password\": \"candidate123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "    pm.collectionVariables.set('access_token', res.access_token);",
                  "}",
                  "if (res.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', res.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/admin/users",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Company",
      "item": [
        {
          "name": "Get All Companies",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/companies"
          }
        },
        {
          "name": "Get Company By ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/companies/{{company_id}}"
          }
        },
        {
          "name": "Create Company (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "    pm.collectionVariables.set('company_id', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/companies",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"description\": \"Acme builds tools for builders.\",\n  \"industry\": \"Software\",\n  \"url\": \"https://acme.example.com\",\n  \"address\": \"123 Main St\",\n  \"city\": \"Springfield\",\n  \"state\": \"IL\",\n  \"country\": \"USA\",\n  \"zip_code\": \"62701\"\n}"
            }
          }
        },
        {
          "name": "Update Company (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/companies/{{company_id}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Acme now builds even better tools.\"\n}"
            }
          }
        },
        {
          "name": "Delete Company (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/companies/{{company_id}}",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        }
      ]
    }
  ]
}
